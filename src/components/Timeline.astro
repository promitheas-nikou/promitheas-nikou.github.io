---
// Timeline.astro
// Drop into your "Experience" / CV page. Pass an array of items as a prop,
// or just edit the `items` fallback below directly.

export interface TimelineItem {
    date: string;          // e.g. "2023 — Present"
    title: string;          // role / position
    organization: string;   // company / firm
    location?: string;      // optional city / remote
    description?: string;   // short blurb of what you did
    tags?: string[];        // tech / skills used
    link?: { label: string; url: string }; // optional featured project / link pill
}

export interface Props {
    items?: TimelineItem[];
}

const {
    items=[]
}: Props = Astro.props;
---

<section class="timeline">
    <!--<h2 class="timeline-heading">{heading}</h2>-->

    <ol class="timeline-track">
        {items.map((item) => (
                <li class="timeline-row">
                    <div class="timeline-rail" aria-hidden="true">
                        <span class="timeline-dot"></span>
                    </div>

                    <div class="timeline-card">
                        <span class="timeline-date">{item.date}</span>
                        <h3 class="timeline-title">{item.title}</h3>
                        <p class="timeline-org">
                            {item.organization}
                            {item.location && <span class="timeline-location"> · {item.location}</span>}
                        </p>

                        {item.description && <p class="timeline-desc">{item.description}</p>}

                        {(item.tags?.length || item.link) && (
                                <div class="timeline-meta">
                                    {item.link && (
                                            <a class="timeline-link" href={item.link.url}>{item.link.label}</a>
                                    )}
                                    {item.tags?.map((tag) => <span class="timeline-tag">{tag}</span>)}
                                </div>
                        )}
                    </div>
                </li>
        ))}
    </ol>
</section>

<style>
    .timeline {
        --ink: #0f172a;
        --muted: #64748b;
        --accent: #6366f1;
        --accent-soft: #eef2ff;
        --border: #e5e7eb;
        --surface: #ffffff;
        --surface-muted: #f8fafc;

        max-width: 760px;
        margin: 0 auto;
        font-family: inherit;
    }

    .timeline-heading {
        font-size: 2em;
        font-weight: 800;
        letter-spacing: -0.02em;
        color: var(--ink);
        margin: 0 0 1.75rem;
    }

    .timeline-track {
        position: relative;
        list-style: none;
        margin: 0;
        padding: 0;
    }

    /* the vertical line */
    .timeline-track::before {
        content: "";
        position: absolute;
        top: 0.4rem;
        bottom: 0.4rem;
        left: 11px;
        width: 2px;
        background: linear-gradient(
                to bottom,
                var(--border) 0%,
                var(--border) 100%
        );
    }

    .timeline-row {
        position: relative;
        display: grid;
        grid-template-columns: 24px 1fr;
        column-gap: 1.25rem;
        margin-bottom: 1.5rem;
    }

    .timeline-row:last-child {
        margin-bottom: 0;
    }

    .timeline-rail {
        position: relative;
        display: flex;
        justify-content: center;
        padding-top: 1.4rem;
    }

    .timeline-dot {
        position: relative;
        width: 12px;
        height: 12px;
        border-radius: 999px;
        background: var(--accent);
        box-shadow: 0 0 0 4px var(--accent-soft);
        z-index: 1;
    }

    .timeline-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 1.1rem 1.25rem 1.25rem;
        box-shadow: 0 1px 2px rgb(15 23 42 / 0.04);
        transition: border-color 0.15s ease, box-shadow 0.15s ease;
    }

    .timeline-card:hover {
        border-color: #c7d2fe;
        box-shadow: 0 2px 8px rgb(99 102 241 / 0.08);
    }

    .timeline-date {
        display: inline-block;
        font-size: 1.5rem;
        font-weight: 700;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        color: var(--accent);
        margin-bottom: 0.4rem;
    }

    .timeline-title {
        font-size: 2rem;
        font-weight: 700;
        color: var(--ink);
        margin: 0 0 0.2rem;
    }

    .timeline-org {
        font-size: 1.25rem;
        color: var(--muted);
        margin: 0 0 0.6rem;
    }

    .timeline-location {
        font-size: 1rem;
        color: var(--muted);
    }

    .timeline-desc {
        font-size: 1rem;
        line-height: 1.55;
        color: #334155;
        margin: 0 0 0.75rem;
    }

    .timeline-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        align-items: center;
    }

    .timeline-tag {
        font-size: 0.75rem;
        font-weight: 600;
        color: var(--accent);
        background: var(--accent-soft);
        border: 1px solid #e0e7ff;
        border-radius: 999px;
        padding: 0.25rem 0.65rem;
    }

    .timeline-link {
        font-size: 0.78rem;
        font-weight: 600;
        color: var(--ink);
        background: var(--surface-muted);
        border: 1px solid var(--border);
        border-radius: 999px;
        padding: 0.3rem 0.75rem;
        text-decoration: none;
        transition: border-color 0.15s ease, background 0.15s ease;
    }

    .timeline-link:hover {
        background: #eef2ff;
        border-color: #c7d2fe;
    }

    @media (max-width: 480px) {
        .timeline-heading {
            font-size: 1.6rem;
        }

        .timeline-row {
            grid-template-columns: 18px 1fr;
            column-gap: 0.85rem;
        }

        .timeline-track::before {
            left: 8px;
        }

        .timeline-dot {
            width: 10px;
            height: 10px;
        }
    }
</style>

